{
	"name": "paytransparency.work",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "svelte-kit sync && vite dev",
		"build": "svelte-kit sync && vite build",
		"preview": "svelte-kit sync && vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"lint": "prettier --check . && svelte-kit sync && eslint .",
		"lint:fix": "prettier --write . --fix && svelte-kit sync && eslint --fix .",
		"format": "prettier --write .",
		"prepare": "husky install"
	},
	"devDependencies": {
		"@svelte-put/inline-svg": "^4.0.2",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.59.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.0",
		"@typescript-eslint/eslint-plugin": "^8.59.2",
		"@typescript-eslint/parser": "^8.59.2",
		"@vite-pwa/sveltekit": "^1.1.0",
		"autoprefixer": "^10.5.0",
		"eslint": "^10.3.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"husky": "^9.1.7",
		"kolorist": "^1.8.0",
		"postcss": "^8.5.14",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.5",
		"svelte-check": "^4.4.8",
		"svelte-query-params": "^0.2.5",
		"tailwindcss": "^4.3.0",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.11",
		"vitest": "^4.1.5",
		"wrangler": "^4.90.0",
		"zod": "^4.4.3",
		"zod-form-data": "^3.0.1"
	},
	"type": "module",
	"dependencies": {
		"@eslint/js": "^10.0.1"
	}
}
